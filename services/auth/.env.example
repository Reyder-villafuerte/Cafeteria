# .env Production profile for docker-compose
SPRING_PROFILES_ACTIVE=prod
CONFIG_SERVER_URL=http://config-server:7071

# MySQL container/app credentials
AUTH_MYSQL_ROOT_PASSWORD=root
AUTH_MYSQL_DATABASE=db_auth

# Spring datasource (used by auth)
AUTH_DB_HOST=mysql-auth
AUTH_DB_PORT=3306
AUTH_DB_NAME=db_auth
AUTH_DB_USERNAME=root
AUTH_DB_PASSWORD=root

JWT_SECRET = prod-secret-key-2026-prod-secret-key-2026-prod-secret-key-2026